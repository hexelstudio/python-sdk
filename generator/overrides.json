{
  "services": {
    "sandbox": {
      "description": "Isolated execution environments",
      "endpoints": {
        "POST /compute/v1/vms/allocate": "create",
        "GET /compute/v1/vms": "list",
        "GET /compute/v1/vms/{id}": "get",
        "DELETE /compute/v1/vms/{id}": "delete",
        "POST /compute/v1/vms/{id}/release": "release",
        "POST /compute/v1/vms/{id}/renew": "renew",
        "POST /compute/v1/vms/{id}/execute": "execute"
      }
    },
    "agent": {
      "description": "Agent registry — register and manage agent images",
      "endpoints": {
        "POST /registry/v1/agents": "register",
        "GET /registry/v1/agents": "list",
        "GET /registry/v1/agents/{id}": "get",
        "PUT /registry/v1/agents/{id}": "update",
        "DELETE /registry/v1/agents/{id}": "delete",
        "GET /registry/v1/agents/search": "search"
      }
    },
    "instance": {
      "description": "Agent deployments — deploy agents and manage instances",
      "endpoints": {
        "POST /compute/v1/agents/{agent_id}/deploy": "deploy",
        "GET /compute/v1/deployments": "list",
        "GET /compute/v1/deployments/{deployment_id}": "get",
        "DELETE /compute/v1/deployments/{deployment_id}": "delete",
        "POST /compute/v1/deployments/{deployment_id}/stop": "stop",
        "POST /compute/v1/deployments/{deployment_id}/redeploy": "redeploy"
      }
    },
    "fleet": {
      "description": "Fleet management — create and configure agent fleets",
      "output_dir": "hexel/orchestrator",
      "endpoints": {
        "POST /orchestrator/v1/fleets": "create",
        "GET /orchestrator/v1/fleets": "list",
        "GET /orchestrator/v1/fleets/{fleet_id}": "get",
        "DELETE /orchestrator/v1/fleets/{fleet_id}": "delete",
        "POST /orchestrator/v1/fleets/{fleet_id}/agents": "add_agent",
        "GET /orchestrator/v1/fleets/{fleet_id}/agents": "list_agents"
      }
    },
    "task": {
      "description": "Task execution — submit goals, review plans, track results",
      "output_dir": "hexel/orchestrator",
      "endpoints": {
        "POST /orchestrator/v1/tasks": "create",
        "GET /orchestrator/v1/tasks": "list",
        "GET /orchestrator/v1/tasks/{task_id}": "get",
        "PUT /orchestrator/v1/tasks/{task_id}/status": "update_status",
        "POST /orchestrator/v1/tasks/{task_id}/plan/approve": "approve_plan",
        "POST /orchestrator/v1/tasks/{task_id}/plan/reject": "reject_plan",
        "GET /orchestrator/v1/tasks/{task_id}/stream": "stream"
      }
    },
    "approval": {
      "description": "Approval workflows — review and approve agent actions",
      "output_dir": "hexel/orchestrator",
      "endpoints": {
        "GET /v1/approvals": "list",
        "POST /v1/approvals": "create",
        "GET /v1/approvals/{id}": "get",
        "POST /v1/approvals/{id}/review": "review",
        "GET /v1/tasks/{task_id}/approvals": "list_by_task"
      }
    }
  },
  "exclude_paths": [
    "/internal/",
    "/compute/v1/pool/",
    "/compute/v1/access/",
    "/compute/v1/skills",
    "/compute/v1/usage",
    "/compute/v1/vms/{id}/r/",
    "/compute/v1/vms/{id}/endpoint",
    "/v1/workflows/execute",
    "/v1/workflows/{id}/cancel",
    "/v1/workflows/{id}/nodes",
    "/v1/workflows/{id}/nodes/{node_id}",
    "/v1/workflows/{workflow_id}/callbacks/{node_id}",
    "/orchestrator/v1/tasks/{task_id}/error",
    "/orchestrator/v1/tasks/{task_id}/result",
    "/orchestrator/v1/fleets/{fleet_id}/resources"
  ],
  "type_renames": {
    "models.AllocateRequest": "CreateSandboxRequest",
    "models.AllocateResponse": "SandboxResponse",
    "models.AgentVM": "SandboxInfo",
    "models.Agent": "InstanceInfo",
    "models.ReleaseRequest": "ReleaseRequest",
    "models.RenewRequest": "RenewRequest",
    "registryclient.Agent": "AgentInfo",
    "models.Fleet": "FleetInfo",
    "models.FleetAgent": "FleetAgentInfo",
    "models.Task": "TaskInfo",
    "models.ApprovalRequest": "ApprovalInfo",
    "models.ReviewRequest": "ReviewRequest"
  },
  "websocket": {
    "sandbox": {
      "url_field": "ws_url",
      "methods": {
        "execute": {"type": "execute", "fields": ["code", "language"]},
        "command": {"type": "command", "fields": ["command"]}
      },
      "terminal_events": ["done", "execution_complete", "error"]
    }
  }
}
