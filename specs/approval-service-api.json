{
    "openapi": "3.0.0",
    "info": {
        "description": "Approval workflows and handling for the Orchestrator Platform",
        "title": "Approval Service API",
        "contact": {},
        "version": "1.0"
    },
    "paths": {
        "/v1/approvals": {
            "get": {
                "description": "List approval requests with optional filtering by org, agent, status, task",
                "tags": [
                    "approvals"
                ],
                "summary": "List approval requests",
                "parameters": [
                    {
                        "description": "Service authentication token",
                        "name": "X-SERVICE-TOKEN",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "description": "Organization ID",
                        "name": "org_id",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "description": "Agent ID",
                        "name": "agent_id",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "description": "Status filter",
                        "name": "status",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "PENDING",
                                "APPROVED",
                                "REJECTED",
                                "EXPIRED"
                            ]
                        }
                    },
                    {
                        "description": "Task ID",
                        "name": "task_id",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "description": "Limit",
                        "name": "limit",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 50
                        }
                    },
                    {
                        "description": "Offset",
                        "name": "offset",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 0
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/approval-service_internal_models.ApprovalRequest"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ErrorResponse"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ErrorResponse"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "description": "Create a new approval request with PENDING status and 24h expiry",
                "tags": [
                    "approvals"
                ],
                "summary": "Create approval request",
                "parameters": [
                    {
                        "description": "Service authentication token",
                        "name": "X-SERVICE-TOKEN",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/approval-service_internal_models.CreateApprovalRequest"
                            }
                        }
                    },
                    "description": "Approval request payload",
                    "required": true
                },
                "responses": {
                    "201": {
                        "description": "Created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ApprovalRequest"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ErrorResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ErrorResponse"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/approvals/{id}": {
            "get": {
                "description": "Retrieve a single approval request by its UUID",
                "tags": [
                    "approvals"
                ],
                "summary": "Get approval request",
                "parameters": [
                    {
                        "description": "Service authentication token",
                        "name": "X-SERVICE-TOKEN",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "description": "Approval request ID",
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ApprovalRequest"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ErrorResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ErrorResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ErrorResponse"
                                }
                            }
                        }
                    }
                }
            },
            "delete": {
                "description": "Cancel a pending approval request",
                "tags": [
                    "approvals"
                ],
                "summary": "Cancel approval request",
                "parameters": [
                    {
                        "description": "Service authentication token",
                        "name": "X-SERVICE-TOKEN",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "description": "Approval request ID",
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No Content"
                    },
                    "400": {
                        "description": "Bad Request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ErrorResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ErrorResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ErrorResponse"
                                }
                            }
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/approvals/{id}/review": {
            "post": {
                "description": "Approve or reject a pending approval request",
                "tags": [
                    "approvals"
                ],
                "summary": "Review approval request",
                "parameters": [
                    {
                        "description": "Service authentication token",
                        "name": "X-SERVICE-TOKEN",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "description": "Approval request ID",
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/approval-service_internal_models.ReviewRequest"
                            }
                        }
                    },
                    "description": "Review payload",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ApprovalRequest"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ErrorResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ErrorResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ErrorResponse"
                                }
                            }
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/tasks/{task_id}/approvals": {
            "get": {
                "description": "List all pending approval requests for a given task ID",
                "tags": [
                    "approvals"
                ],
                "summary": "List pending approvals by task",
                "parameters": [
                    {
                        "description": "Service authentication token",
                        "name": "X-SERVICE-TOKEN",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "description": "Task ID",
                        "name": "task_id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/approval-service_internal_models.ApprovalRequest"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ErrorResponse"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/approval-service_internal_models.ErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "//localhost:8015"
        }
    ],
    "components": {
        "securitySchemes": {
            "ServiceToken": {
                "type": "apiKey",
                "name": "X-SERVICE-TOKEN",
                "in": "header"
            }
        },
        "schemas": {
            "approval-service_internal_models.ApprovalRequest": {
                "type": "object",
                "properties": {
                    "action": {
                        "type": "string"
                    },
                    "agent_id": {
                        "type": "string"
                    },
                    "comment": {
                        "type": "string"
                    },
                    "context": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "string"
                        }
                    },
                    "created_at": {
                        "type": "string"
                    },
                    "expires_at": {
                        "type": "string"
                    },
                    "id": {
                        "type": "string"
                    },
                    "node_id": {
                        "type": "string"
                    },
                    "org_id": {
                        "type": "string"
                    },
                    "policy_id": {
                        "type": "string"
                    },
                    "requested_by": {
                        "type": "string"
                    },
                    "resource": {
                        "type": "string"
                    },
                    "reviewed_at": {
                        "type": "string"
                    },
                    "reviewed_by": {
                        "type": "string"
                    },
                    "status": {
                        "$ref": "#/components/schemas/approval-service_internal_models.Status"
                    },
                    "task_id": {
                        "type": "string"
                    }
                }
            },
            "approval-service_internal_models.CreateApprovalRequest": {
                "type": "object",
                "required": [
                    "action",
                    "agent_id",
                    "node_id",
                    "org_id",
                    "policy_id",
                    "requested_by",
                    "resource",
                    "task_id"
                ],
                "properties": {
                    "action": {
                        "type": "string"
                    },
                    "agent_id": {
                        "type": "string"
                    },
                    "context": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "string"
                        }
                    },
                    "node_id": {
                        "type": "string"
                    },
                    "org_id": {
                        "type": "string"
                    },
                    "policy_id": {
                        "type": "string"
                    },
                    "requested_by": {
                        "type": "string"
                    },
                    "resource": {
                        "type": "string"
                    },
                    "task_id": {
                        "type": "string"
                    }
                }
            },
            "approval-service_internal_models.ErrorResponse": {
                "type": "object",
                "properties": {
                    "details": {
                        "type": "string"
                    },
                    "error": {
                        "type": "string"
                    }
                }
            },
            "approval-service_internal_models.ReviewRequest": {
                "type": "object",
                "required": [
                    "decision",
                    "reviewed_by"
                ],
                "properties": {
                    "comment": {
                        "type": "string"
                    },
                    "decision": {
                        "$ref": "#/components/schemas/approval-service_internal_models.Status"
                    },
                    "reviewed_by": {
                        "type": "string"
                    }
                }
            },
            "approval-service_internal_models.Status": {
                "type": "string",
                "enum": [
                    "PENDING",
                    "APPROVED",
                    "REJECTED",
                    "EXPIRED"
                ],
                "x-enum-varnames": [
                    "StatusPending",
                    "StatusApproved",
                    "StatusRejected",
                    "StatusExpired"
                ]
            }
        }
    }
}